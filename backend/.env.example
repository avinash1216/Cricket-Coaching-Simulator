# GCP Project ID
GCP_PROJECT=cricket-coach-mvp

# Gemini API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# Firestore database (use default)
FIRESTORE_DATABASE=(default)

# Server
HOST=0.0.0.0
PORT=8080

# Decision window duration in seconds
DECISION_WINDOW_SECONDS=25

# Simulation speed (seconds between balls)
BALL_INTERVAL_SECONDS=5
OVER_PAUSE_SECONDS=8

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://cricket-coach-mvp.web.app
